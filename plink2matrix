matrix_cast <- function(comparison_table, sample_names){
  ## Turning input into an incomplete pairwise comparison matrix 
	preprocess_trianglematrix<-as.matrix(
    as.data.frame.matrix(
      xtabs(V3 ~ V1 + V2,
            data=comparison_table
            )
      )
  )

  # Checking if the input dataset has more non-zero values than expected for a triangular matrix
  if(sum(preprocess_trianglematrix > 0) > sum(lower.tri(preprocess_trianglematrix, diag=TRUE))){
    write("The input dataset has more non-zero values than expected. Exiting before processing.\n", stderr());
    quit(save="no", status=1)
  }
  
  ## Determining what sample names are missing from these matrices: Plink leaves some out
  missing_row <<- as.character(sample_names[!(sample_names %in% rownames(preprocess_trianglematrix))])
  missing_col <<- as.character(sample_names[!(sample_names %in% colnames(preprocess_trianglematrix))])
  
  overlapping_sample_names <- rownames(preprocess_trianglematrix)[rownames(preprocess_trianglematrix)%in%colnames(preprocess_trianglematrix)]
  

  # Trying to catch weirdness: Plink should skip two samples naturally. This ensures that's the case
  if( length(missing_row)>1 
	|| length(missing_col)>1 ){
    write("I am expeting one missing sample in the rownames or colnames, your input has more than one for one of them.\n", stderr())
    
	  write("Writing a debugging report...\n", stderr())
	  debugging_report_saver(matrices=c("preprocess_trianglematrix"),
						failed_test="length(missing_row)>1 || length(missing_col)>1")
	
    write("Saving intermediate matrix for debugging...\n", stderr())
	
	  tsv_writer(matrix_to_save = preprocess_trianglematrix,
			   name = paste(substitute(comparison_table),
				 "_preprocess_trianglematrix.failedvariable.tsv",
				 sep=""))
  
	  write("Exiting...\n", stderr())
    quit(save="no", status=1)
  }
  
  
  ## Reordering row names and column names. This step assumes that:
  # >The sample missing from the column names has the row with most non-zero values.
  # >The sample missing from the row names has the column with most zero values.
  ## It will output a triangular matrix, where:
  # >A column name is missing from the row names
  # >A row name is missing from the column names
  preprocess_trianglematrix <- preprocess_trianglematrix[
    c(overlapping_sample_names, missing_col),
    c(missing_row, overlapping_sample_names)
  ]
  
  ## Ensuring a triangular matrix format (can be triangular but unorganized)
  if(sum(preprocess_trianglematrix[upper.tri(preprocess_trianglematrix, diag=FALSE)])>0 
    && sum(diag(preprocess_trianglematrix)>0)!=0 ){
    
    # A variable for later debug report
    triangular_matrix_reordering <- TRUE
    
    # Reorganizes triangular matrix of the overlapping set of sample names
    overlapping_sample_matrix <- preprocess_trianglematrix[overlapping_sample_names, overlapping_sample_names]

    overlapping_sample_matrix <- ( t(overlapping_sample_matrix) + overlapping_sample_matrix ) * ( lower.tri(overlapping_sample_matrix, diag = FALSE) + 0 )
    
    preprocess_trianglematrix[overlapping_sample_names, overlapping_sample_names] <- overlapping_sample_matrix

    triangle_matrix <- preprocess_trianglematrix
    
  }else{
    
    # In case that it is ordered as a triangular matrix
    triangle_matrix <- preprocess_trianglematrix
    
    # Making sure it includes the missing names
    triangle_matrix <- rbind( rep(0,dim(triangle_matrix)[2]), triangle_matrix )
    rownames(triangle_matrix)[1] <- as.character(missing_row)
    
    triangle_matrix <- cbind( triangle_matrix, rep(0,dim(triangle_matrix)[1]))
    colnames(triangle_matrix)[dim(triangle_matrix)[1]] <- as.character(missing_col)
    
  }
  

  ## Ensuring that:
	#the matrix is a lower triangular matrix
    #is missing row/col names (expected)
	#that it's offset by 1 (no diagonal)
  if( (length(missing_row)==1 
  	 || length(missing_col)==1 ) 
  	&& sum(diag(triangle_matrix)>0)!=0 ){

    triangle_matrix<-rbind(rep(0,dim(triangle_matrix)[2]),triangle_matrix)
    rownames(triangle_matrix)[1]<-missing_row
  
    triangle_matrix<-cbind(triangle_matrix,rep(0,dim(triangle_matrix)[1]))
    colnames(triangle_matrix)[dim(triangle_matrix)[2]]<-missing_col
  
    
  # Unexpected, but benign:
    # It is a lower triangular matrix, but has a diagonal sum of 0 
	# Is not missing col/row names 
  }else if( (length(missing_row)==0 
  		   || length(missing_col)==0 ) 
  		  && sum(diag(triangle_matrix)>0)==0 ){

    break
 
  # Unexpected and erroneous:
  	# There are missing col/row names (expected), 
  	# But the triangular matrix has a diagonal sum of 0
	# And has a diagonal sum != 0
#   }else if( 
# 			(length(missing_row)>0 || length(missing_col)>0 ) 
# 			&& ( sum(diag(triangle_matrix)>0)==0 )
# 			&& ( sum(diag(triangle_matrix[,-1])>0)!=0 )
# 		   ){
#     
#     #Trying to catch any unexpected cases of weird Plink output
#     write("The `triangle_matrix` variable is missing the colnames/rownames as expected, but...
# 	>It's diagonal sum == 0.
# 	>It's superdiagonal sum !=0
# 
# This is an accounted for edge-case: Exiting.\n", stderr())
# 
#   	debugging_report_saver(matrices=c("preprocess_trianglematrix",
#   									   "triangle_matrix"),
#   							test_failed="(
# 	length(missing_row)>0 
#   	|| length(missing_col)>0 
# ) && ( sum(diag(triangle_matrix)>0)==0 ) 
# && ( sum(diag(triangle_matrix[,-1])>0)!=0 )")
# 
#     write("Saving intermediate matrices for debugging...\n", stderr())
#     tsv_writer(matrix_to_save = preprocess_trianglematrix,
#     		   name = paste(substitute(comparison_table), 
#     		   			 "_preprocess_trianglematrix.failedvariable.tsv", 
#     		   			 sep=""))
#     tsv_writer(matrix_to_save = triangle_matrix,
#     		   name = paste(substitute(comparison_table), 
#     		   			 "_triangle_matrix.failedvariable.tsv", 
#     		   			 sep=""))
#     
#     quit(save="no", status=1)
#   
  }

  if( sum(rownames(triangle_matrix)!=colnames(triangle_matrix) )>0){
    
  	write("Rownames and colnames of `triangle_matrix` variable are not in the same order, contact Luis.\n", stderr())
  	debugging_report_saver(matrices=c("preprocess_trianglematrix",
  									   "triangle_matrix"),
  							test_failed="sum(rownames(triangle_matrix)!=colnames(triangle_matrix))>0")
  	
  	write("Saving intermediate matrices for debugging...\n", stderr())
  	tsv_writer(matrix_to_save = preprocess_trianglematrix,
  			   name = paste(substitute(comparison_table), 
  			   			 "_preprocess_trianglematrix.failedvariable.tsv", 
  			   			 sep=""))
  	tsv_writer(matrix_to_save = triangle_matrix,
  			   name = paste(substitute(comparison_table), 
  			   			 "_triangle_matrix.failedvariable.tsv", 
  			   			 sep=""))
  	
    quit(save="no", status=1)
  }
  
  ## Making symmetrical matrix from lower triangle matrix
  finalmatrix <- t(triangle_matrix) + triangle_matrix
  
  # Returning matrix with predefined global sample order (always the same).
  if(isSymmetric(finalmatrix) 
     && sum(finalmatrix==Inf)==0 
     && sum(diag(finalmatrix)>0)==0){
    
    finalmatrix[as.character(sample_names), as.character(sample_names)]
  
  }else{
    
    write("The final output matrix has some irregularities... Writing a debugging report.\n", stderr())
      
  	debugging_report_saver(matrices=c("preprocess_trianglematrix",
  									   "triangle_matrix",
  									   "finalmatrix"),
  							test_failed="isSymmetric(finalmatrix) && sum(finalmatrix==Inf)==0 && sum(diag(finalmatrix)>0)==0")
  	
  	
    write("Saving intermediate matrices for debugging...\n", stderr())
    
    tsv_writer(matrix_to_save = preprocess_trianglematrix,
    		   name = paste(substitute(comparison_table), 
    		   			 "_preprocess_trianglematrix.failedvariable.tsv", 
    		   			 sep=""))
   
	tsv_writer(matrix_to_save = triangle_matrix,
			   name = paste(substitute(comparison_table), 
			   			 "_trianglematrix.failedvariable.tsv", 
			   			 sep=""))
	
	tsv_writer(matrix_to_save = finalmatrix,
			   name = paste(substitute(comparison_table), 
			   			 "_finalmatrix.failedvariable.tsv", 
			   			 sep=""))
	
	write("Exiting.\n", stderr())
    quit(save="no", status = 1)
  }
}



