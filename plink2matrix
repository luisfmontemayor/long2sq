file_loader <- function(arguments){
  if(file.exists(arguments[1])){
    INPUTSOURCE<<-as.character(arguments[1])
  }else{
    cat(paste(arguments[1], " is not a file... Exiting.\n", sep=""))
    quit(save="no", status=1)
  }
}


args <- commandArgs(trailingOnly = TRUE)

if(sum(c("-h", "--help") %in% args[1])>=1){
  usage()
  quit(save="no", status=0)
}

if(length(args)==1){
  file_loader(arguments=args)
	
}else if( length(args)<1 ){
  cat("You have to give me some arguments...\n")
  usage()
  quit(save="no", status=1)

}else if( length(args)>2 ){
  cat("You gave me too many arguments...\n")
  usage()
  quit(save="no", status=1)
}


tsv_writer<-function(matrix_to_save, name){
	write.table(matrix_to_save, 
				file = as.character(name), 
				quote = F, 
				sep="\t", 
				row.names = TRUE, 
				col.names = NA)
}

phylip_writer<-function(matrix_to_save, name){
	
	writeLines(as.character(sample_names_length),
			   con = as.character(name))
	
	write.table(matrix_to_save,
				file = as.character(name),
				quote = FALSE,
				sep="\t",
				row.names = TRUE,
				col.names = FALSE,
				append = TRUE)
}


