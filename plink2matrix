kin0_sample_shared_sites <-  read.table(
	file(paste(INPUTSOURCE)), 
	sep = "\t", 
	as.is=TRUE
)[,c(1,2,3)]

sdiff_pairwise_distances <- read.table(
	file(paste(INPUTSOURCE)), 
	sep = "\t", 
	as.is=TRUE
)[,c(1,2,4)]
colnames(sdiff_pairwise_distances)<-c("V1","V2","V3")

sample_names <- unique(
	sort(
		c(kin0_sample_shared_sites$V1,
		  kin0_sample_shared_sites$V2,
		  sdiff_pairwise_distances$V1,
		  sdiff_pairwise_distances$V2
		)
	)
)

sample_names_length <- length(sample_names)



### Body =======================================================================
## Making the matrices from the Plink pairwise comparison tables
write("Processing sdiff distances...\n", stderr())
sdiff_matrix <- matrix_cast(comparison_table=sdiff_pairwise_distances, sample_names=sample_names)

write("Processing kin0 distances...\n", stderr())
kin0_sample_shared_sites_matrix <- matrix_cast(comparison_table=kin0_sample_shared_sites, sample_names=sample_names)


## Normalizing the matrix
write("Computing normalized distance matrix...\n", stderr())

#Old Normalization: normalised_matrix <- (sdiff_matrix / kin0_sample_shared_sites_matrix) * mean(colSums(kin0_sample_shared_sites_matrix) / nrow(kin0_sample_shared_sites_matrix)) 

normalised_matrix <- sdiff_matrix/( sdiff_matrix + kin0_sample_shared_sites_matrix ) 

normalised_matrix[is.na(normalised_matrix)] <- 0
normalised_matrix[is.nan(normalised_matrix)] <- 0




### Outputting #################################################################
#Making a numbering system for repeated file names in WD (to avoid overwritting)
filenumber<-length(list.files(pattern = paste(INPUTSOURCE, "final_normalized_matrix.phylip",sep="")))

if( filenumber > 0){
  
  SDIFFNAME <- paste(INPUTSOURCE, "_sdiff_matrix_", filenumber, sep="")
  KIN0NAME <- paste(INPUTSOURCE, "_kin0_matrix_", filenumber, sep="")
  OUTPUTFILENAME <- paste(INPUTSOURCE, "_final_normalized_matrix_", filenumber, sep="")
  
}else{
  
  SDIFFNAME <- paste(INPUTSOURCE, "_sdiff_matrix", sep="")
  KIN0NAME <- paste(INPUTSOURCE, "_kin0_matrix", sep="")
  OUTPUTFILENAME <- paste(INPUTSOURCE, "_final_normalized_matrix", sep="")
  
}


## SDIFF matrices
phylip_writer(matrix_to_save = sdiff_matrix,
			  name = paste(SDIFFNAME, ".phylip", sep=""))

tsv_writer(matrix_to_save = sdiff_matrix,
		   name = paste(SDIFFNAME, ".tsv", sep=""))


#KIN0 matrices
phylip_writer(matrix_to_save = kin0_sample_shared_sites_matrix,
			  name = paste(KIN0NAME, ".phylip", sep=""))

tsv_writer(matrix_to_save = kin0_sample_shared_sites_matrix,
		   name = paste(KIN0NAME, ".tsv", sep=""))


# Final normalized matrix
phylip_writer(matrix_to_save = normalised_matrix,
		   name = paste(OUTPUTFILENAME, ".phylip", sep=""))

tsv_writer(matrix_to_save = normalised_matrix,
		   name = paste(OUTPUTFILENAME, ".tsv", sep=""))


write("Saved PHYLIPs and TSVs for the kin0, sdiff and normalized (final) matrices.\n", stderr())
quit(save="no", status=0)
